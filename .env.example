# ════════════════════════════════════════════════════════════
#  TerremotoTracker — Variáveis de Ambiente
#  Copie este arquivo: cp .env.example .env
#  NUNCA commite o .env real no Git!
# ════════════════════════════════════════════════════════════

# ── Ambiente ─────────────────────────────────────────────────
ENVIRONMENT=development          # development | production | test

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=terremoto
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=terremoto_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL completa montada pelo backend (não edite se usar os campos acima)
DATABASE_URL=postgresql+asyncpg://terremoto:supersecretpassword@db:5432/terremoto_db

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=redissecretpassword
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:redissecretpassword@redis:6379/0

# ── pgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@terremoto.dev
PGADMIN_PASSWORD=pgadminpassword

# ── FastAPI / Segurança ──────────────────────────────────────
SECRET_KEY=troque-por-uma-string-aleatoria-de-64-chars-minimo
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── APIs Externas ────────────────────────────────────────────
# USGS Earthquake API — sem autenticação necessária
USGS_BASE_URL=https://earthquake.usgs.gov/fdsnws/event/1
USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary

# Smithsonian GVP — sem autenticação necessária
GVP_BASE_URL=https://volcano.si.edu/api

# Open-Meteo — sem autenticação necessária
OPEN_METEO_URL=https://api.open-meteo.com/v1

# ── Cache ─────────────────────────────────────────────────────
CACHE_TTL_SECONDS=60             # TTL do cache Redis para dados da USGS
CACHE_TTL_VOLCANOES=3600         # Vulcões mudam raramente — 1 hora

# ── Frontend (prefixo VITE_ obrigatório pro Vite expor ao browser) ──
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
